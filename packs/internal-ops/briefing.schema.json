{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["_meta"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["generated_at", "valid_until", "pack_name", "schema_version"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "valid_until": { "type": "string", "format": "date-time" },
        "pack_name": { "type": "string" },
        "schema_version": { "type": "string" }
      }
    },
    "leadership": { "type": "object" },
    "people_on_vacation": { "type": "array", "items": { "type": "object", "required": ["name"] } },
    "recent_hires_departures": { "type": "object" },
    "current_priorities": { "type": "array", "items": { "type": "object", "required": ["title"] } },
    "active_incidents": { "type": "array" },
    "internal_tool_versions": { "type": "object" },
    "corrections": { "type": "array", "items": { "type": "object", "required": ["wrong", "right"] } },
    "upcoming_events": { "type": "array" }
  }
}
