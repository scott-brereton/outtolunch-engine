{
  "type": "object",
  "required": ["_meta", "data"],
  "properties": {
    "_meta": { "type": "object" },
    "data": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "since": { "type": "string", "format": "date" },
            "previous": { "type": "string" }
          }
        }
      }
    }
  }
}
