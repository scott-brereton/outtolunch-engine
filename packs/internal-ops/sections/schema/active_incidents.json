{
  "type": "object",
  "required": ["_meta", "data"],
  "properties": {
    "_meta": { "type": "object" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "severity"],
        "properties": {
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["sev1", "sev2", "sev3"] },
          "started_at": { "type": "string", "format": "date-time" },
          "owner": { "type": "string" },
          "brief_status": { "type": "string" }
        }
      }
    }
  }
}
