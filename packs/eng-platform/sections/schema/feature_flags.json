{
  "type": "object",
  "required": ["_meta", "data"],
  "properties": {
    "_meta": { "type": "object" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "state"],
        "properties": {
          "name": { "type": "string" },
          "state": { "type": "string", "enum": ["enabled", "disabled", "ramping"] },
          "rollout_pct": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    }
  }
}
